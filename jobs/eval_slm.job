#!/bin/bash

#SBATCH --partition=gpuA
#SBATCH --gpus=1
#SBATCH -c 8
#SBATCH --ntasks=1
#SBATCH --time=4:00:00
#SBATCH --output=/dev/null

set -euo pipefail

module load apps/binapps/conda/miniforge3/25.9.1
module load libs/cuda/12.4.1

BASE="/mnt/iusers01/fse-ugpgt01/compsci01/j84846ky/scratch/34812-cwk-S-Project"

RUN_DIR="$BASE/runs/slm/eval"
ADAPTER_PATH="$BASE/models/slm_adapter_demo"
mkdir -p "$RUN_DIR"

exec > >(tee "$RUN_DIR/output_$(date +%Y-%m-%d_%H-%M).log") 2>&1

echo "===== Job started at $(date) ====="
echo "RUN_ID: $SLURM_JOB_ID"

echo "Creating venv in $TMPDIR..."
python -m venv "$TMPDIR/venv"
source "$TMPDIR/venv/bin/activate"

echo "Installing requirements..."
pip install --quiet -r "$BASE/requirements/requirements-hpc.txt"
echo "Install complete at $(date)"

export PYTHONPATH="$BASE:${PYTHONPATH:-}"
export HF_HOME="$BASE/.cache/huggingface"

echo "===== SLM eval started at $(date) ====="
CUDA_VISIBLE_DEVICES=0 python -u -m src.slm_utils.eval_slm --adapter-path "$ADAPTER_PATH" --run-dir "$RUN_DIR"
echo "===== SLM eval finished at $(date) ====="
